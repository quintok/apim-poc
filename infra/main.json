        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', format('{0}-deleg', parameters('apimName')))]",
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}-law', parameters('apimName')))]"
      ]
    },
    {
      "condition": "[parameters('enableDelegation')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), resourceId('Microsoft.Web/sites', format('{0}-deleg', parameters('apimName'))), variables('keyVaultSecretsUserRoleId'))]",
