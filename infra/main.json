            "instanceMemoryMB": "[parameters('delegationHandlerInstanceMemoryMB')]"
          }
        },
        "siteConfig": {
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "appSettings": [
