      ]
    },
    {
      "condition": "[and(parameters('enableDelegation'), not(empty(parameters('auth0ClientSecret'))))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'auth0-client-secret')]",
      "properties": {
        "value": "[parameters('auth0ClientSecret')]"
      },
      "dependsOn": [
