      }
    },
    {
      "condition": "[parameters('enableObservability')]",
      "type": "Microsoft.ApiManagement/service/loggers",
      "apiVersion": "2023-05-01-preview",
      "name": "[format('{0}/{1}', parameters('apimName'), 'applicationinsights')]",
      "properties": {
        "loggerType": "applicationInsights",
