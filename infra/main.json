        "resourceId": "[resourceId('Microsoft.Insights/components', format('{0}-ai', parameters('apimName')))]",
        "credentials": {
          "connectionString": "[reference(resourceId('Microsoft.Insights/components', format('{0}-ai', parameters('apimName'))), '2020-02-02').ConnectionString]"
        },
        "isBuffered": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.ApiManagement/service', parameters('apimName'))]",
        "[resourceId('Microsoft.Insights/components', format('{0}-ai', parameters('apimName')))]"
      ]
    },
    {
      "condition": "[parameters('enableObservability')]",
      "type": "Microsoft.ApiManagement/service/diagnostics",
      "apiVersion": "2023-05-01-preview",
      "name": "[format('{0}/{1}', parameters('apimName'), 'applicationinsights')]",
      "properties": {
        "loggerId": "[resourceId('Microsoft.ApiManagement/service/loggers', parameters('apimName'), 'applicationinsights')]",
        "alwaysLog": "allErrors",
        "sampling": {
          "samplingType": "fixed",
          "percentage": 100
        },
        "httpCorrelationProtocol": "W3C",
        "verbosity": "information",
        "logClientIp": true,
        "frontend": {
          "request": {
            "headers": [
              "x-correlation-id"
            ]
          },
          "response": {}
        },
        "backend": {
          "request": {},
          "response": {}
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ApiManagement/service', parameters('apimName'))]",
        "[resourceId('Microsoft.ApiManagement/service/loggers', parameters('apimName'), 'applicationinsights')]"
      ]
