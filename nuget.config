<?xml version="1.0" encoding="utf-8"?>
<!--
  nuget.config
  Adds the repo-root `packages/` folder as a local NuGet feed. This is how
  we consume the Azure API Management Policy Toolkit `.nupkg` files until
  they are published on nuget.org. See README "Bootstrap" section for the
  step-by-step download instructions.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-toolkit" value="./packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
